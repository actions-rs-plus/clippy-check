{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": ["github>kristof-mattei/renovate-config"],
    "forkProcessing": "enabled",
    "hostRules": [
        {
            "matchHost": "https://npm.pkg.github.com/",
            "hostType": "npm",
            "token": "{{ secrets.NPM_TOKEN }}"
        }
    ]
}
