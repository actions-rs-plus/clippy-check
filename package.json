{
    "private": false,
    "name": "@actions-rs-plus/clippy-check",
    "version": "0.0.0",
    "author": "actions-rs-plus",
    "license": "MIT",
    "description": "Run clippy and annotate the diff with errors and warnings",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts"
    ],
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "engines": {
        "node": "24.14.1",
        "pnpm": "10.33.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/actions-rs-plus/clippy-check.git"
    },
    "keywords": [
        "actions",
        "rust",
        "cargo"
    ],
    "bugs": {
        "url": "https://github.com/actions-rs-plus/clippy-check/issues"
    },
    "scripts": {
        "build": "vite build && mkdir -p dist/.matchers && cp matchers/rust.json dist/.matchers/rust.json",
        "watch": "vite build --watch",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "pnpm run lint --fix",
        "format": "prettier --write .",
        "clean": "rm -rf ./dist/* && rm tsconfig.tsbuildinfo && pnpm run build",
        "test": "vitest --coverage.enabled=true",
        "deps:ci": "depcruise --config dependency-cruiser.config.mjs --output-type err src",
        "deps:graph": "depcruise --config dependency-cruiser.config.mjs --output-type dot src | dot -T svg > dependency-graph.svg",
        "deps:report": "depcruise --config dependency-cruiser.config.mjs --output-type err-html --output-to dependency-report.html src",
        "postversion": "cp package.json pnpm-lock.yaml ..",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "depcruise --config dependency-cruiser.config.mjs --validate -- "
        ],
        "*": [
            "eslint -- ",
            "prettier --ignore-unknown --"
        ]
    },
    "dependencies": {
        "@actions-rs-plus/core": "0.6.5",
        "@actions/core": "3.0.0",
        "@actions/exec": "3.0.0",
        "source-map-support": "0.5.21",
        "string-argv": "0.3.2"
    },
    "devDependencies": {
        "@actions/io": "3.0.2",
        "@codecov/vite-plugin": "1.9.1",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.1",
        "@eslint/config-helpers": "0.5.3",
        "@eslint/js": "10.0.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/eslint": "9.6.1",
        "@types/node": "24.12.0",
        "@types/semver": "7.7.1",
        "@types/source-map-support": "0.5.10",
        "@typescript-eslint/parser": "8.57.2",
        "@vitest/coverage-v8": "4.1.2",
        "@vitest/ui": "4.1.2",
        "dependency-cruiser": "17.3.10",
        "eslint": "10.1.0",
        "eslint-config-love": "151.0.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-node": "0.3.9",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import-x": "4.16.2",
        "eslint-plugin-n": "17.24.0",
        "eslint-plugin-perfectionist": "5.7.0",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-promise": "7.2.1",
        "eslint-plugin-unicorn": "63.0.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "prettier": "3.8.1",
        "semver": "7.7.4",
        "typescript": "6.0.2",
        "typescript-eslint": "8.57.2",
        "vite": "8.0.3",
        "vite-plugin-checker": "0.12.0",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.1.2"
    },
    "pnpm": {
        "overrides": {
            "@codecov/vite-plugin>vite": "8.0.3",
            "undici": "7.24.6"
        }
    }
}
