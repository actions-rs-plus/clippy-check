{
    "private": false,
    "name": "@actions-rs-plus/clippy-check",
    "version": "0.0.0",
    "author": "actions-rs-plus",
    "license": "MIT",
    "description": "Run clippy and annotate the diff with errors and warnings",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/**/*.js",
        "dist/**/*.js.map",
        "dist/**/*.d.ts"
    ],
    "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
    "engines": {
        "node": "24.18.0",
        "pnpm": "11.10.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/actions-rs-plus/clippy-check.git"
    },
    "keywords": [
        "actions",
        "rust",
        "cargo"
    ],
    "bugs": {
        "url": "https://github.com/actions-rs-plus/clippy-check/issues"
    },
    "scripts": {
        "build": "vite build && mkdir -p dist/.matchers && cp matchers/rust.json dist/.matchers/rust.json",
        "watch": "vite build --watch",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint:fix": "pnpm run lint --fix",
        "format": "prettier --write .",
        "clean": "rm -rf ./dist/* && rm tsconfig.tsbuildinfo && pnpm run build",
        "test": "vitest --coverage.enabled=true",
        "deps:ci": "depcruise --config dependency-cruiser.config.mjs --output-type err src",
        "deps:graph": "depcruise --config dependency-cruiser.config.mjs --output-type dot src | dot -T svg > dependency-graph.svg",
        "deps:report": "depcruise --config dependency-cruiser.config.mjs --output-type err-html --output-to dependency-report.html src",
        "postversion": "cp package.json pnpm-lock.yaml ..",
        "prepare": "husky"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "depcruise --config dependency-cruiser.config.mjs --validate -- "
        ],
        "*": [
            "eslint -- ",
            "prettier --ignore-unknown --"
        ]
    },
    "dependencies": {
        "@actions-rs-plus/core": "0.7.5",
        "@actions/core": "3.0.1",
        "@actions/exec": "3.0.0",
        "source-map-support": "0.5.21",
        "string-argv": "0.3.2",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@actions/io": "3.0.2",
        "@codecov/vite-plugin": "2.0.1",
        "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
        "@eslint/config-helpers": "0.6.0",
        "@eslint/core": "1.2.1",
        "@eslint/js": "10.0.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/eslint": "9.6.1",
        "@types/node": "24.13.2",
        "@types/semver": "7.7.1",
        "@types/source-map-support": "0.5.10",
        "@typescript-eslint/parser": "8.62.1",
        "@vitest/coverage-v8": "4.1.10",
        "@vitest/ui": "4.1.10",
        "dependency-cruiser": "18.0.0",
        "eslint": "catalog:default",
        "eslint-config-love": "154.0.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-import-resolver-node": "0.4.0",
        "eslint-import-resolver-typescript": "4.4.5",
        "eslint-plugin-import-x": "4.17.1",
        "eslint-plugin-n": "18.2.1",
        "eslint-plugin-perfectionist": "5.9.1",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-promise": "7.3.0",
        "eslint-plugin-unicorn": "70.0.0",
        "husky": "9.1.7",
        "jiti": "2.7.0",
        "lint-staged": "17.0.8",
        "prettier": "3.9.4",
        "prettier-plugin-sh": "0.18.1",
        "prettier-plugin-toml": "2.0.6",
        "semver": "7.8.5",
        "typescript": "6.0.3",
        "typescript-eslint": "8.62.1",
        "vite": "catalog:default",
        "vite-plugin-checker": "0.14.4",
        "vitest": "4.1.10"
    }
}
